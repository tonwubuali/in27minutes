# Copy to .env (for local `vercel dev`) and set the same vars in your Vercel project.

# Neon Postgres connection string (Project → Connection Details → "Pooled connection").
# Looks like: postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Any long random string. Used to sign login tokens.
JWT_SECRET=
